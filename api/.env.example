PORT=4000

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_PUBLIC=iis_public

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT
JWT_SECRET=change_me_super_secret_min32chars
JWT_EXPIRES_IN=24h
REFRESH_SECRET=change_me_refresh_secret_min32chars
REFRESH_EXPIRES_IN=7d

# File uploads
UPLOAD_DIR=./uploads

# Nodemailer (use Mailtrap for dev)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@iis.local

# CORS origins
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001

# AI Assistant (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
