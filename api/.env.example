PORT=4000

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=iis
DB_SCHEMA_PUBLIC=platform

# JWT (values in seconds)
JWT_SECRET=change_me_super_secret_min32chars
JWT_EXPIRES_IN=86400
REFRESH_SECRET=change_me_refresh_secret_min32chars
REFRESH_EXPIRES_IN=604800

# File uploads
UPLOAD_DIR=./uploads

# Email (use Mailtrap for dev)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@iis.local

# CORS origins
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001

# WhatsApp (optional — leave blank to disable)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
